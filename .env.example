# Copia questo file in .env (già in .gitignore) e inserisci le tue chiavi reali.
# Usato da `netlify dev` per iniettare le variabili nelle Netlify Functions locali.
# Almeno una chiave è necessaria; le altre sono usate come fallback ciclico.
#
# Gemini — https://aistudio.google.com/apikey
CHAT_GEMINI_API_KEY=
# Groq — https://console.groq.com/keys
CHAT_GROQ_API_KEY=
